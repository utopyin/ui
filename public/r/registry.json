        }
      ],
      "dependencies": ["@base-ui/react", "tailwind-variants"],
      "registryDependencies": [
        "https://ui.utopy.sh/r/focus-ring.json",
        "https://ui.utopy.sh/r/utils.json",
        "https://ui.utopy.sh/r/theme.json"
      ]
