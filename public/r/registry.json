        "light": {
          "background": "oklch(1 0 0)",
          "foreground": "oklch(0.145 0 0)",
          "secondary": "var(--color-zinc-100)",
          "outline": "var(--color-zinc-100)",
          "outline-foreground": "var(--color-zinc-950)",
          "outline-hover": "var(--color-zinc-200)",
          "accent": "oklch(0.694 0.146 239)",
          "accent-300": "oklch(0.694 0.146 239)",
          "accent-600": "oklch(0.519 0.12 242)",
          "accent-700": "oklch(0.426 0.0951 240)",
          "accent-foreground": "oklch(1 0 0)",
          "border": "oklch(0 0 0 / 8%)",
          "input": "oklch(0 0 0 / 12%)"
        },
        "dark": {
          "background": "oklch(0.145 0 0)",
          "foreground": "oklch(0.985 0 0)",
          "secondary": "var(--color-zinc-800)",
          "outline": "var(--color-zinc-850)",
          "outline-foreground": "var(--color-zinc-50)",
          "outline-hover": "var(--color-zinc-700)",
          "accent": "oklch(0.269 0 0)",
          "accent-300": "oklch(0.694 0.146 239)",
          "accent-600": "oklch(0.519 0.12 242)",
          "accent-700": "oklch(0.426 0.0951 240)",
          "accent-foreground": "oklch(0.985 0 0)",
          "border": "oklch(1 0 0 / 10%)",
          "input": "oklch(1 0 0 / 15%)"
        }
      }
    },
    {
